// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "context_server_timeout": 60,
  "edit_predictions": {
    "mode": "eager",
  },
  "show_edit_predictions": false,
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4o",
    },
    "default_profile": "ask",
    "model_parameters": [],
  },
  "features": {
    "edit_prediction_provider": "zed",
  },
  "project_panel": {
    "hide_hidden": false,
  },
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "blinking": "on",
    "cursor_shape": "underline",
  },
  "active_pane_modifiers": {},
  "bottom_dock_layout": "contained",
  "tabs": {
    "show_close_button": "hover",
    "file_icons": true,
    "git_status": false,
  },
  "tab_bar": {
    "show": true,
  },
  "title_bar": {
    "show_branch_name": true,
    "show_project_items": true,
    "show_onboarding_banner": true,
    "show_sign_in": false,
    "show_menus": false,
    "show_user_picture": true,
    "show_branch_icon": false,
  },
  "toolbar": {
    "quick_actions": true,
    "selections_menu": true,
    "agent_review": true,
    "code_actions": false,
  },
  "relative_line_numbers": "enabled",
  "autosave": "off",
  "selection_highlight": true,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "agent_ui_font_size": 16.0,
  "ui_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_family": "FiraCode Nerd Font",
  "use_system_prompts": false,
  "use_system_path_prompts": false,
  "icon_theme": "Colored Zed Icons Theme Dark",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "ui_font_size": 19.0,
  "buffer_font_size": 23.0,
  "theme": {
    "mode": "system",
    "light": "Dracula Solid",
    "dark": "Everforest Dark Hard",
  },
  "lsp": {
    "lua-language-server": {
      "binary": {
        "ignore_system_version": false,
        "path": "/bin/lua-language-server",
        "arguments": ["--loglevel=info", "--stdio"],
        "env": {
          "LUA_PATH": "/usr/share/lua/5.4/?.lua",
          "LUA_CPATH": "/usr/lib/lua/5.4/?.so",
        },
      },
    },
  },
}
